# --- Public Firebase web config (safe to expose — not secrets) ---
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_APP_ID=

# Set to "true" to point the client SDK at the local emulator (dev only).
PUBLIC_USE_FIREBASE_EMULATOR=false

# --- Server-only (never PUBLIC_) ---
# Admin SDK credentials. Use ONE of:
#   FIREBASE_SERVICE_ACCOUNT_PATH  — path to the downloaded JSON file (local dev)
#   FIREBASE_SERVICE_ACCOUNT       — the JSON as a single-line string (deploy/serverless)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-admin.json
FIREBASE_SERVICE_ACCOUNT=
READ_PASSCODE_HASH=
UNLOCK_COOKIE_SECRET=
